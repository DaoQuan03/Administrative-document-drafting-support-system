# SMTP EMAIL CONFIGURATION (Dùng Gmail hoặc máy chủ SMTP khác)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=email_cua_ban@gmail.com
EMAIL_HOST_PASSWORD=mat_khau_ung_dung_gmail_cua_ban
DEFAULT_FROM_EMAIL="VănBảnAI <noreply@vanbanai.vn>"

# GOOGLE OAUTH2 CREDENTIALS
# Đăng ký tại: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/accounts/google/callback/

# MICROSOFT OAUTH2 CREDENTIALS (MS TEAMS)
# Đăng ký tại: https://portal.azure.com/ (Azure Active Directory / App Registrations)
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_REDIRECT_URI=http://127.0.0.1:8000/accounts/microsoft/callback/

# OPENAI API CONFIGURATION (Dùng cho nhúng vector và tìm kiếm chính xác cao)
OPENAI_API_KEY=sk-proj-YourOpenAIAPIKeyHere

# OLLAMA CONFIGURATION (Dùng cho AI cục bộ chạy offline miễn phí 100%)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
